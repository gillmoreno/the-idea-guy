# Baked in at build time (Next.js static export). Copy to .env.local for local dev overrides.

# Default relay for all rooms (WebSocket)
# NEXT_PUBLIC_RELAY_URL=ws://localhost:4500

# Public app URL (QR codes, deep links)
# NEXT_PUBLIC_APP_URL=http://localhost:3300

# Show Settings → Sync relay (custom relay URL). Disabled unless true.
# NEXT_PUBLIC_RELAY_SETTINGS_ENABLED=true
