{
  "version": 1,
  "templates": [
    {
      "id": "potluck",
      "name": "Potluck",
      "description": "Who brings what — dietary tags and headcount for shared meals.",
      "emoji": "🥗",
      "accent": "#22c55e",
      "schema": {
        "schemaVersion": 1,
        "engineVersion": 1,
        "id": "potluck",
        "name": "Potluck",
        "description": "Plan a shared meal — claim dishes and note dietary needs.",
        "emoji": "🥗",
        "accent": "#22c55e",
        "collections": [
          {
            "id": "dishes",
            "label": "Dishes",
            "singular": "dish",
            "fields": [
              { "key": "title", "label": "Dish", "type": "text", "required": true },
              { "key": "notes", "label": "Notes", "type": "textarea" },
              { "key": "dietary", "label": "Dietary tags", "type": "tags" }
            ],
            "views": ["list", "add"],
            "permissions": { "create": "member", "edit": "member" }
          }
        ],
        "features": [
          {
            "type": "status",
            "collection": "dishes",
            "values": [
              { "id": "needed", "label": "Needed" },
              { "id": "claimed", "label": "Claimed" },
              { "id": "brought", "label": "Brought" }
            ],
            "setBy": "member"
          }
        ]
      }
    },
    {
      "id": "idea-pool",
      "name": "Idea Pool",
      "description": "Propose ideas and vote — a lightweight backlog for any group.",
      "emoji": "💡",
      "accent": "#f59e0b",
      "schema": {
        "schemaVersion": 1,
        "engineVersion": 1,
        "id": "idea-pool",
        "name": "Idea Pool",
        "description": "Collect proposals and vote on what to do next.",
        "emoji": "💡",
        "accent": "#f59e0b",
        "collections": [
          {
            "id": "ideas",
            "label": "Ideas",
            "singular": "idea",
            "fields": [
              { "key": "title", "label": "Title", "type": "text", "required": true },
              { "key": "pitch", "label": "Pitch", "type": "textarea", "required": true }
            ],
            "views": ["list", "add"],
            "permissions": { "create": "member" }
          }
        ],
        "features": [
          { "type": "votes", "collection": "ideas", "onePerMember": true },
          {
            "type": "status",
            "collection": "ideas",
            "values": [
              { "id": "proposed", "label": "Proposed" },
              { "id": "building", "label": "Building" },
              { "id": "shipped", "label": "Shipped" },
              { "id": "parked", "label": "Parked" }
            ],
            "setBy": "owner"
          }
        ]
      }
    },
    {
      "id": "grocery-run",
      "name": "Grocery Run",
      "description": "Shared shopping list — add items, claim \"I'll grab it\", tick off when bought.",
      "emoji": "🛒",
      "accent": "#0ea5e9",
      "schema": {
        "schemaVersion": 1,
        "engineVersion": 1,
        "id": "grocery-run",
        "name": "Grocery Run",
        "description": "One list for the household — see what's needed, claim items, mark them bought.",
        "emoji": "🛒",
        "accent": "#0ea5e9",
        "collections": [
          {
            "id": "items",
            "label": "Items",
            "singular": "item",
            "fields": [
              { "key": "title", "label": "Item", "type": "text", "required": true },
              { "key": "qty", "label": "Quantity / size", "type": "text" },
              { "key": "notes", "label": "Notes", "type": "textarea" },
              { "key": "store", "label": "Store / aisle", "type": "tags" }
            ],
            "views": ["list", "add"],
            "permissions": { "create": "member", "edit": "member" }
          }
        ],
        "features": [
          {
            "type": "status",
            "collection": "items",
            "values": [
              { "id": "needed", "label": "Needed" },
              { "id": "grabbing", "label": "I'll grab it" },
              { "id": "bought", "label": "Bought" }
            ],
            "setBy": "member"
          }
        ]
      }
    },
    {
      "id": "appointment-huddle",
      "name": "Appointment Huddle",
      "description": "Find one slot everyone can make — propose times, vote, confirm.",
      "emoji": "📅",
      "accent": "#8b5cf6",
      "schema": {
        "schemaVersion": 1,
        "engineVersion": 1,
        "id": "appointment-huddle",
        "name": "Appointment Huddle",
        "description": "Propose time slots, vote on what works, and let the organizer confirm one.",
        "emoji": "📅",
        "accent": "#8b5cf6",
        "collections": [
          {
            "id": "slots",
            "label": "Time slots",
            "singular": "slot",
            "fields": [
              { "key": "title", "label": "When", "type": "text", "required": true },
              { "key": "where", "label": "Where", "type": "text" },
              { "key": "notes", "label": "Notes", "type": "textarea" }
            ],
            "views": ["list", "add"],
            "permissions": { "create": "member", "edit": "member" }
          }
        ],
        "features": [
          { "type": "votes", "collection": "slots", "onePerMember": true },
          {
            "type": "status",
            "collection": "slots",
            "values": [
              { "id": "proposed", "label": "Proposed" },
              { "id": "confirmed", "label": "Confirmed ✓" },
              { "id": "dropped", "label": "Doesn't work" }
            ],
            "setBy": "owner"
          }
        ]
      }
    },
    {
      "id": "watch-club",
      "name": "Watch Club",
      "description": "Decide what to watch together — propose, vote, track what you've seen.",
      "emoji": "🍿",
      "accent": "#f43f5e",
      "schema": {
        "schemaVersion": 1,
        "engineVersion": 1,
        "id": "watch-club",
        "name": "Watch Club",
        "description": "A shared watchlist — propose movies and series, vote on what's next, and mark what you've watched.",
        "emoji": "🍿",
        "accent": "#f43f5e",
        "collections": [
          {
            "id": "titles",
            "label": "Watchlist",
            "singular": "title",
            "fields": [
              { "key": "title", "label": "Title", "type": "text", "required": true },
              { "key": "kind", "label": "Type / genre", "type": "tags" },
              { "key": "where", "label": "Where to watch", "type": "text" },
              { "key": "notes", "label": "Why this one?", "type": "textarea" }
            ],
            "views": ["list", "add"],
            "permissions": { "create": "member", "edit": "member" }
          }
        ],
        "features": [
          { "type": "votes", "collection": "titles", "onePerMember": true },
          {
            "type": "status",
            "collection": "titles",
            "values": [
              { "id": "queue", "label": "In the queue" },
              { "id": "watching", "label": "Watching" },
              { "id": "watched", "label": "Watched" }
            ],
            "setBy": "member"
          }
        ]
      }
    }
  ]
}
