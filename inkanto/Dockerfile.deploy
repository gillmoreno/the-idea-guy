# ---- stage 1: frontend ----
FROM node:20-slim AS frontend-build
WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm install
COPY frontend/ ./
RUN npm run build

# ---- stage 2: go api ----
FROM --platform=$BUILDPLATFORM golang:1.23-alpine AS go-build
WORKDIR /src
COPY go-backend/go.mod go-backend/go.sum* ./
RUN go mod download || true
COPY go-backend/ ./
ARG TARGETOS TARGETARCH
RUN go mod tidy && CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o /out/inkanto-api ./cmd/server

# ---- stage 3: sidecar deps ----
FROM node:20-slim AS sidecar-build
WORKDIR /app/ai-sidecar
COPY ai-sidecar/package*.json ./
RUN npm install --omit=dev
COPY ai-sidecar/src ./src

# ---- final: nginx + go + node sidecar in one container ----
# node:20-slim (glibc) base — the Agent SDK ships a native claude binary
# that is not guaranteed to run on musl/alpine.
FROM node:20-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends nginx supervisor ca-certificates \
 && rm -rf /var/lib/apt/lists/*

COPY --from=frontend-build /app/frontend/dist /usr/share/nginx/html
COPY --from=go-build /out/inkanto-api /usr/local/bin/inkanto-api
COPY --from=sidecar-build /app/ai-sidecar /app/ai-sidecar
COPY skills /app/skills
COPY nginx.deploy.conf /etc/nginx/conf.d/default.conf
RUN rm -f /etc/nginx/sites-enabled/default
COPY supervisord.deploy.conf /etc/supervisord.conf

RUN mkdir -p /data

ENV PORT=8080 \
    SIDECAR_PORT=8090 \
    SIDECAR_URL=http://127.0.0.1:8090 \
    SKILLS_DIR=/app/skills \
    DATABASE_PATH=/data/inkanto.sqlite3

EXPOSE 80
CMD ["supervisord", "-c", "/etc/supervisord.conf"]
