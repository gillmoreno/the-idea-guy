# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=

# Accounts — there is no signup page. Comma-separated user:password pairs are
# created at startup if missing (existing users are never touched).
INKANTO_USERS=

# From `claude setup-token` (1-year token, tied to your Claude subscription).
# The Agent SDK draws from your plan's monthly Agent SDK credit.
CLAUDE_CODE_OAUTH_TOKEN=

# Model used by the coach
INKANTO_MODEL=claude-opus-4-8
