# Cloudflare (required for deploy-subdomain.sh)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: override the baked-in relay URL at build time (default: wss://relay.the-idea-guy.com)
# NEXT_PUBLIC_RELAY_URL=wss://relay.the-idea-guy.com

# Show Settings → Sync relay (custom relay URL) in Rooms / ChoreBoard. Off by default.
# Add to deploy/subdomains.json build_env when enabling production builds:
#   "NEXT_PUBLIC_RELAY_SETTINGS_ENABLED": "${NEXT_PUBLIC_RELAY_SETTINGS_ENABLED}"
# NEXT_PUBLIC_RELAY_SETTINGS_ENABLED=true
