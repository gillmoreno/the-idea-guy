# Cloudflare (required for deploy-subdomain.sh)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: override the baked-in relay URL at build time (default: wss://relay.the-idea-guy.com)
# Self-hosters can also set a custom relay in the app under Settings → Sync relay.
# NEXT_PUBLIC_RELAY_URL=wss://relay.the-idea-guy.com
