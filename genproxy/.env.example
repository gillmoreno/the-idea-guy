# genproxy credentials & knobs — copy to genproxy/.env (gitignored) and fill in.
# Full reference: docs_and_changelog/ROOM_AI.md

# Provider: "anthropic" (default — official Claude SDK) or "openai" (any
# OpenAI-compatible endpoint, e.g. OpenCode Zen or the local claude-sidecar)
# GENPROXY_PROVIDER=anthropic

# REQUIRED — the platform AI key.
#   anthropic: an Anthropic API key (console.anthropic.com); ANTHROPIC_API_KEY also works
#   openai:    e.g. your OpenCode Zen key (https://opencode.ai/zen)
GENPROXY_API_KEY=

# --- Option: Claude subscription via local sidecar (no API billing) ---
# The Inkanto pattern: claude-sidecar/ wraps the Claude Agent SDK and your
# CLAUDE_CODE_OAUTH_TOKEN (`claude setup-token` → claude-sidecar/.env), and
# exposes an OpenAI-compatible endpoint on localhost. Then use:
# GENPROXY_PROVIDER=openai
# GENPROXY_UPSTREAM_URL=http://127.0.0.1:4601/v1/chat/completions
# GENPROXY_MODEL=claude-haiku-4-5
# GENPROXY_API_KEY=local-sidecar
# GENPROXY_PRICE_IN_USD=0                  # subscription credit is the real meter
# GENPROXY_PRICE_OUT_USD=0

# Model (defaults by provider)
# GENPROXY_MODEL=claude-haiku-4-5          # anthropic default (~$0.0035/generation)
# GENPROXY_MODEL=deepseek-v4-flash         # openai/Zen default (~$0.0004/generation)

# OpenAI-compatible endpoint (openai provider only)
# GENPROXY_UPSTREAM_URL=https://opencode.ai/zen/v1/chat/completions

# Spend & abuse rails
# GENPROXY_MONTHLY_BUDGET_USD=10           # hard cap → budget_exhausted (≈2,800 Haiku gens)
# GENPROXY_PRICE_IN_USD / GENPROXY_PRICE_OUT_USD  # $/1M tokens for the spend meter;
#                                          # defaults: 1.00/5.00 (anthropic), 0.14/0.28 (openai)
# GENPROXY_GENS_PER_IP_HOUR=20
# GENPROXY_MAX_DESC_CHARS=500
# GENPROXY_MAX_TOKENS=1600

# Server
# GENPROXY_ADDR=:4600
# GENPROXY_DATA_DIR=                       # set to persist the monthly spend meter
# GENPROXY_ALLOW_ORIGIN=*                  # lock to the PWA origin in production
